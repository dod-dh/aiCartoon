# ── 이미지 생성 (필수) ─────────────────────────────
# Google AI Studio 무료 API 키: https://aistudio.google.com/apikey
# 무료 티어: 약 1,500 요청/일, 60 RPM
GEMINI_API_KEY=

# 이미지 모델 (Nano Banana 계열). 사용 가능 목록은 계정마다 다를 수 있음
#   예) gemini-3.1-flash-image (권장) / gemini-2.5-flash-image / gemini-3-pro-image
IMAGE_MODEL=gemini-3.1-flash-image

# ── 대본/콘티 생성 ─────────────────────────────────
# gemini   : 위 GEMINI_API_KEY 하나로 대본까지 생성 (기본, 추천)
# anthropic: Claude API 사용 (ANTHROPIC_API_KEY 필요)
# manual   : LLM 없이 비트를 1:1 컷 초안으로만 변환 후 직접 작성
SCRIPT_PROVIDER=gemini
SCRIPT_MODEL=gemini-flash-latest

# SCRIPT_PROVIDER=anthropic 일 때만 필요
#   https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── 폴백 이미지 제공자 (선택) ──────────────────────
# 키 없이 즉시 사용 가능하지만 얼굴 일관성은 보장 못 함. 테스트/프리뷰용.
FALLBACK_IMAGE_PROVIDER=pollinations
