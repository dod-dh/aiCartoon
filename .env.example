# ── 이미지 생성 (과금) ─────────────────────────────
# 결제(billing) 활성화된 프로젝트의 키. 이미지 생성에만 사용됨.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 이미지 모델 (Nano Banana 계열). 무료 티어는 limit:0 → 결제 필요.
#   예) gemini-2.5-flash-image (저렴) / gemini-3-pro-image(고품질)
IMAGE_MODEL=gemini-2.5-flash-image

# ── 대본/콘티 생성 (무료로 유지) ───────────────────
# gemini   : Gemini 텍스트로 대본 생성 (기본)
# anthropic: Claude API 사용 (ANTHROPIC_API_KEY 필요)
# manual   : LLM 없이 비트를 1:1 컷 초안으로만 변환 후 직접 작성
SCRIPT_PROVIDER=gemini
SCRIPT_MODEL=gemini-flash-latest

# 대본을 "무조건 무료"로 돌리려면: 결제 안 된 별도 프로젝트에서 키를 발급해 여기에 넣기.
# (비우면 위 GEMINI_API_KEY로 폴백 → 결제 프로젝트라 소액 과금될 수 있음)
GEMINI_TEXT_API_KEY=

# ── 폴백 이미지 제공자 (선택) ──────────────────────
# 키 없이 즉시 사용 가능하지만 얼굴 일관성은 보장 못 함. 테스트/프리뷰용.
FALLBACK_IMAGE_PROVIDER=pollinations
